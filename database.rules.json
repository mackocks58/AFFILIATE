{
  "rules": {
    "betslips": {
      ".read": true,
      "$id": {
        ".write": "auth != null && auth.token.admin === true"
      }
    },
    "betslipCodes": {
      "$id": {
        ".read": "auth != null && (auth.token.admin === true || root.child('purchases').child(auth.uid).child($id).child('status').val() === 'completed')",
        ".write": "auth != null && auth.token.admin === true"
      }
    },
    "purchases": {
      "$uid": {
        "$betslipId": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      }
    },
    "checkoutSessions": {
      ".read": false,
      ".write": false
    },
    "userPayments": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        ".write": false
      }
    },
    "supportTickets": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        "$ticketId": {
          ".write": "auth != null && (auth.uid === $uid || auth.token.admin === true)"
        }
      }
    },
    "users": {
      ".indexOn": ["affiliateCode"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "referrals": {
      "$code": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('affiliateCode').val() === $code",
        ".write": "auth != null"
      }
    },
    "chatChannels": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "chatMessages": {
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "userFollowing": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },
    "userReads": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
