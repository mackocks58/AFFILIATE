{
  "rules": {
    "betslips": {
      ".read": true,
      "$id": {
        ".write": "auth != null && auth.token.admin === true"
      }
    },
    "betslipCodes": {
      "$id": {
        ".read": "auth != null && (auth.token.admin === true || root.child('purchases').child(auth.uid).child($id).child('status').val() === 'completed')",
        ".write": "auth != null && auth.token.admin === true"
      }
    },
    "purchases": {
      "$uid": {
        "$betslipId": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      }
    },
    "checkoutSessions": {
      ".read": false,
      ".write": false
    },
    "withdrawals": {
      ".indexOn": ["uid"],
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && (auth.token.admin === true || newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      }
    },
    "manualPayments": {
      ".indexOn": ["uid", "status"],
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && (auth.token.admin === true || newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      }
    },
    "userPayments": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        ".write": false
      }
    },
    "supportTickets": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        "$ticketId": {
          ".write": "auth != null && (auth.uid === $uid || auth.token.admin === true)"
        }
      }
    },
    "users": {
      ".read": "auth != null",
      ".indexOn": ["affiliateCode", "referredBy", "username"],
      "$uid": {
        ".write": "auth != null && (auth.token.admin === true || auth.uid === $uid)"
      }
    },
    "commissions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },
    "settings": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    "quizzes": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },
    "userQuizzes": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "referrals": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null"
      }
    },
    "chatChannels": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "chatMessages": {
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "userFollowing": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },
    "userReads": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "userUnread": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },
    "bundles": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    "bundleRequests": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && (auth.token.admin === true || newData.child('uid').val() === auth.uid)"
      }
    }
  }
}
