# Client (Vite) — copy to .env and fill
# Production (Firebase Hosting): full origin of your deployed payment API, no trailing slash.
# Example: https://betslips-api-xxxxx.run.app   Leave unset locally (Vite proxies /api to port 8787).
VITE_API_BASE_URL=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT.firebaseio.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Payment API (Express on port 8787) — copy same vars into .env at project root for the server
FIREBASE_DATABASE_URL=https://YOUR_PROJECT.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Public URL of the web app (Selcom redirect/cancel). Local: http://localhost:5173
# Production: your Firebase Hosting URL, e.g. https://YOUR_PROJECT.web.app
PUBLIC_APP_URL=http://localhost:5173

# After enabling Hosting: Firebase Console → Authentication → Settings → Authorized domains
# should include YOUR_PROJECT.web.app and YOUR_PROJECT.firebaseapp.com

# Must be a public HTTPS URL in production so Selcom can call your webhook (tunnel ngrok, deploy, etc.)
SELCOM_WEBHOOK_PUBLIC_URL=http://localhost:8787

SELCOM_VENDOR_ID=
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_LIVE=false
SELCOM_ORDER_PREFIX=BS
SELCOM_PAYMENT_EXPIRY_MINUTES=60
SELCOM_HEADER_COLOR=#0b1220
SELCOM_LINK_COLOR=#7dd3fc
SELCOM_BUTTON_COLOR=#34d399

# When running: ADMIN_UID=<uid> npm run set-admin
ADMIN_UID=
